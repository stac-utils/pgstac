#!/bin/bash
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
cd $SCRIPT_DIR/..

function usage() {
	cat <<EOF
Usage: $(basename "$0") [options]

Run formatting checks inside the pypgstac development container.

Options:
  --build-policy POLICY   One of: always, missing, never. Default: always.
  -h, --help              Show this help text.
EOF
}

BUILD_POLICY="${PGSTAC_BUILD_POLICY:-always}"

while [[ $# -gt 0 ]]; do
	case "$1" in
		--build-policy)
			BUILD_POLICY="$2"
			shift 2
			;;
		-h|--help)
			usage
			exit 0
			;;
		*)
			echo "Unknown option: $1" >&2
			usage
			exit 1
			;;
	esac
done

$SCRIPT_DIR/runinpypgstac --build-policy "$BUILD_POLICY" --cpfiles format
