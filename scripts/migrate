#!/bin/bash
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
cd $SCRIPT_DIR/..

function usage() {
	cat <<EOF
Usage: $(basename "$0") [options] [pypgstac migrate args...]

Run pypgstac migrations inside the development container.

Options:
  --build-policy POLICY   One of: always, missing, never. Default: always.
  -h, --help              Show this help text.
EOF
}

BUILD_POLICY="${PGSTAC_BUILD_POLICY:-always}"
POSITIONAL=()

while [[ $# -gt 0 ]]; do
	case "$1" in
		--build-policy)
			BUILD_POLICY="$2"
			shift 2
			;;
		-h|--help)
			usage
			exit 0
			;;
		*)
			POSITIONAL+=("$1")
			shift
			;;
	esac
done

$SCRIPT_DIR/runinpypgstac --build-policy "$BUILD_POLICY" pypgstac migrate "${POSITIONAL[@]}"
